{
  "permissions": {
    "allow": [
      "Bash(~/.config/vibe-tools/claude-callback.sh *)",
      "Bash(~/.config/vibe-tools/claude-delegate.sh *)",
      "Bash(~/.config/vibe-tools/claude-send.sh *)",
      "Bash(/Users/eunsol/.claude/plugins/marketplaces:*)",
      "Bash(/Users/eunsol/.claude/plugins/cache:*)",
      "Bash(iconv *)",
      "Bash(iconv:*)",
      "Bash(file *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(grep:*)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(mkdir *)",
      "Bash(rm /tmp/*)",
      "Bash(rm -f /tmp/*)",
      "Bash(cp /tmp/*)",
      "Bash(cp -f /tmp/*)",
      "Bash(mv /tmp/*)",
      "Bash(mv -f /tmp/*)",
      "Bash(cat /tmp/*)",
      "Bash(diff /tmp/*)",
      "Bash(diff -u /tmp/*)",
      "Bash(head /tmp/*)",
      "Bash(tail /tmp/*)",
      "Bash(file /tmp/*)",
      "Bash(file -I /tmp/*)",
      "Bash(ls /tmp/*)",
      "Bash(ls -la /tmp/*)",
      "Bash(stat /tmp/*)",
      "Bash(wc /tmp/*)",
      "Bash(wc -l /tmp/*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf ..:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard origin/*)",
      "Bash(git reset --hard upstream/*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D:*)",
      "Bash(git filter-branch:*)",
      "Bash(chmod -R 777:*)",
      "Bash(dd if=/dev/*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/harness-reminder.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Read stdin. Extract tool_input.command. If it does NOT contain 'git commit', immediately output {\"continue\":true} without calling any tools. If it contains 'git commit': 1) Run Bash to get staged PHP files: git diff --cached --name-only --diff-filter=ACMR | grep '\\.php$' 2) If no PHP files, output {\"continue\":true} 3) For each staged PHP file use lsp_diagnostics tool to check diagnostics 4) If any error-severity diagnostics exist, output {\"continue\":false,\"stopReason\":\"❌ LSP 오류로 커밋 차단\\n\\n오류를 수정한 뒤 다시 커밋하세요.\\n\\n오류 목록:\\n<list errors>\"} 5) If no errors output {\"continue\":true}",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/settings-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/project-docs-init.sh\"",
            "timeout": 10,
            "statusMessage": "프로젝트 문서 디렉터리 확인 중..."
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/worktree-setup.sh\"",
            "timeout": 60,
            "statusMessage": "워크트리 초기화 중..."
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".gradle",
      ".cache",
      "build"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /Users/eunsol/.claude/plugins/cache/claude-dashboard/claude-dashboard/1.27.0/dist/index.js"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "oh-my-claudecode@omc": false,
    "analyze@swkim0128": true,
    "nworks@swkim0128": true,
    "test@swkim0128": true,
    "tmux-suite@swkim0128": true,
    "git-suite@swkim0128": true,
    "vibe-admin@swkim0128": true,
    "harness@swkim0128": true,
    "task-mgmt@swkim0128": true,
    "notify@swkim0128": true,
    "notion-suite@swkim0128": true,
    "php-lsp@claude-plugins-official": true,
    "plane-mcp@cc-claude": true,
    "google-workspace@swkim0128": true,
    "claude-dashboard@claude-dashboard": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "swkim0128": {
      "source": {
        "source": "git",
        "url": "https://github.com/swkim0128/vibe-claude-plugin.git"
      },
      "autoUpdate": true
    },
    "claude-dashboard": {
      "source": {
        "source": "github",
        "repo": "uppinote20/claude-dashboard"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
