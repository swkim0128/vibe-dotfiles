{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/harness-reminder.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/worktree-setup.sh\"",
            "timeout": 60,
            "statusMessage": "워크트리 초기화 중..."
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", ".gradle", ".cache"]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/find-node.sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "notion@claude-plugins-official": true,
    "notion-suite@swkim0128": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "editorMode": "vim"
}
