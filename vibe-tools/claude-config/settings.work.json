{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/harness-reminder.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/worktree-setup.sh\"",
            "timeout": 60,
            "statusMessage": "워크트리 초기화 중..."
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", ".gradle", ".cache", "build"]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud-cache.sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "analyze@cc-claude": true,
    "backend@cc-claude": true,
    "beginner@cc-claude": true,
    "cc-utils@cc-claude": true,
    "context-architect@cc-claude": true,
    "enterprise-base@cc-claude": true,
    "harness@cc-claude": true,
    "plane-mcp@cc-claude": true,
    "workflow@cc-claude": true,
    "legacy@cc-claude": true,
    "test@cc-claude": true,
    "nworks@cc-claude": true,
    "prompt-search@cc-claude": true,
    "tmux-suite@swkim0128": true,
    "git-suite@swkim0128": true,
    "legacy-suite@swkim0128": true,
    "task-mgmt@swkim0128": true,
    "vibe-admin@swkim0128": true,
    "notify@swkim0128": true,
    "notion-suite@swkim0128": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "swkim0128": {
      "source": {
        "source": "git",
        "url": "https://github.com/swkim0128/vibe-claude-plugin.git"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark-daltonized",
  "editorMode": "vim"
}
