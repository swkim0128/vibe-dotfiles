{
  "permissions": {
    "allow": [
      "Bash(~/.config/vibe-tools/claude-callback.sh *)",
      "Bash(~/.config/vibe-tools/claude-delegate.sh *)",
      "Bash(~/.config/vibe-tools/claude-send.sh *)",
      "Bash(iconv *)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/harness-reminder.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/plugins/marketplaces/swkim0128/plugins/tmux-suite/skills/tmux-session-start/scripts/tmux-session-guard.sh\"",
            "timeout": 5
          },
          {
            "type": "agent",
            "prompt": "Read stdin. Extract tool_input.command. If it does NOT contain 'git commit', immediately output {\"continue\":true} without calling any tools. If it contains 'git commit': 1) Run Bash to get staged PHP files: git diff --cached --name-only --diff-filter=ACMR | grep '\\.php$' 2) If no PHP files, output {\"continue\":true} 3) For each staged PHP file use lsp_diagnostics tool to check diagnostics 4) If any error-severity diagnostics exist, output {\"continue\":false,\"stopReason\":\"❌ LSP 오류로 커밋 차단\\n\\n오류를 수정한 뒤 다시 커밋하세요.\\n\\n오류 목록:\\n<list errors>\"} 5) If no errors output {\"continue\":true}",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/settings-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/worktree-setup.sh\"",
            "timeout": 60,
            "statusMessage": "워크트리 초기화 중..."
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".gradle",
      ".cache",
      "build"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud-cache.sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "analyze@cc-claude": true,
    "backend@cc-claude": true,
    "cc-utils@cc-claude": true,
    "context-architect@cc-claude": true,
    "enterprise-base@cc-claude": true,
    "harness@cc-claude": true,
    "plane-mcp@cc-claude": true,
    "workflow@cc-claude": true,
    "legacy@cc-claude": true,
    "test@cc-claude": true,
    "nworks@cc-claude": true,
    "prompt-search@cc-claude": true,
    "tmux-suite@swkim0128": true,
    "git-suite@swkim0128": true,
    "legacy-suite@swkim0128": true,
    "task-mgmt@swkim0128": true,
    "vibe-admin@swkim0128": true,
    "harness@swkim0128": true,
    "para-mgmt@swkim0128": true,
    "notify@swkim0128": true,
    "notion-suite@swkim0128": true,
    "php-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "swkim0128": {
      "source": {
        "source": "git",
        "url": "https://github.com/swkim0128/vibe-claude-plugin.git"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark-daltonized",
  "editorMode": "vim"
}
